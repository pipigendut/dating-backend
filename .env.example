# Database
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Run Port
PORT=8080

# Storage Config
STORAGE_PROVIDER=ORACLE # Options: ORACLE, AWS

# Oracle Object Storage (S3 Compatible)
# Get these from OCI Console -> Profile -> Customer Secret Keys
S3_ACCESS_KEY=
S3_SECRET_KEY==
# Endpoint format: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
S3_ENDPOINT=
S3_REGION=
S3_BUCKET_NAME=
# Optional: Base URL for public access to objects
S3_PUBLIC_URL=

# JWT
JWT_SECRET=

# Token Expiry
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# Kafka Config
KAFKA_BROKERS=localhost:9092

# ONNX Face Verification
FACE_VERIFICATION_PROVIDER=onnx
ONNX_MODEL_PATH=./models/arcface_resnet50.onnx
ONNXRUNTIME_SHARED_LIBRARY_PATH=./lib/libonnxruntime.dylib

